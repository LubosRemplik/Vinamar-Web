POSTGRES_USER=vinamar
POSTGRES_PASSWORD=vinamar
POSTGRES_DB=vinamar
DATABASE_URL=postgres://vinamar:vinamar@db:5432/vinamar
API_PORT=3001
WEB_PORT=3000
# Browser talks to the API same-origin; Next.js rewrites /api → the api service
# (API_PROXY_TARGET, set in docker-compose.yml). This works both on localhost and
# behind the Tailscale MagicDNS hostname without hardcoding a host.
NEXT_PUBLIC_API_URL=/api
# SECURITY: the values below are LOCAL-DEV defaults only. Before any non-local
# deployment, set strong values (e.g. openssl rand -hex 32 for JWT_SECRET).
JWT_SECRET=change-me
ADMIN_USERNAME=owner
ADMIN_PASSWORD=change-me
OWNER_EMAIL=owner@example.com
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM=vinamar@example.com
MAIL_FROM_NAME=Vinamar
# SECURITY: PUBLIC_BASE_URL is the public origin used to build links in outgoing
# emails (e.g. booking confirmation links). MUST be set to the real public URL
# before any non-local deployment — the localhost default is dev-only.
PUBLIC_BASE_URL=http://localhost:3000
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_MARKER=
FLIGHTS_HORIZON_MONTHS=9
# Leave empty to disable the manual refresh endpoint; set a high-entropy token to enable it.
FLIGHTS_REFRESH_TOKEN=

# --- Tailscale (access the app from your tailnet via MagicDNS over HTTPS) ---
# MagicDNS hostname of the node → app reachable at https://${TS_HOSTNAME}.<your-tailnet>.ts.net
TS_HOSTNAME=vinamar
# Put the reusable auth key in .env.local (git-ignored), NOT here:
#   TS_AUTHKEY=tskey-auth-xxxx…
